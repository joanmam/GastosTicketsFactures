# Configuració del client Firebase (Project settings > General > Your apps > SDK setup and configuration)
NEXT_PUBLIC_FIREBASE_API_KEY="..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="el-teu-projecte.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="el-teu-projecte"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="el-teu-projecte.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="..."
NEXT_PUBLIC_FIREBASE_APP_ID="..."

# Compte de servei de Firebase (Project settings > Service accounts > Generate new private key)
# Enganxa aquí el contingut SENCER del fitxer JSON en una sola línia
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...", ...}'

# Bucket de Firebase Storage (normalment el-teu-projecte.appspot.com)
FIREBASE_STORAGE_BUCKET="el-teu-projecte.appspot.com"

# Clau API d'Anthropic per a l'extracció de dades dels tickets
ANTHROPIC_API_KEY="sk-ant-..."
# Model a utilitzar (opcional, per defecte claude-sonnet-4-6)
ANTHROPIC_MODEL="claude-sonnet-4-6"
